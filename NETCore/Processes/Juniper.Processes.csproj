<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<AssemblyName>Juniper.Processes</AssemblyName>
		<RootNamespace>Juniper.Processes</RootNamespace>
    <PackageId>STM.Juniper.Processes</PackageId>
		<OutputType>Library</OutputType>
		<TargetFramework>net7.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<Platforms>AnyCPU;x64</Platforms>
		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
		<Description>Utility code for managing subprocesses, and wrappers around some common CLI commands.</Description>
		<PackageLicenseFile>..\..\LICENSE.md</PackageLicenseFile>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Debug'">
		<DebugType>portable</DebugType>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<DebugType>none</DebugType>
	</PropertyGroup>

	<ItemGroup>
	  <None Include="..\..\..\.editorconfig" Link=".editorconfig" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\IO\Juniper.IO.csproj" />
	  <ProjectReference Include="..\MediaType\Juniper.MediaType.csproj" />
	  <ProjectReference Include="..\Root\Juniper.Root.csproj" />
	</ItemGroup>

</Project>
