<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<AssemblyName>Juniper.IO</AssemblyName>
		<RootNamespace>Juniper.IO</RootNamespace>
    <PackageId>STM.Juniper.IO</PackageId>
		<OutputType>Library</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<Platforms>AnyCPU;x64</Platforms>
		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
		<Description>Stream-based IO utilities, such as streamlined de/serialization and read/write progress tracking.</Description>
		<PackageLicenseFile>..\..\LICENSE.md</PackageLicenseFile>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Debug'">
		<DebugType>portable</DebugType>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<DebugType>none</DebugType>
	</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\MediaType\Juniper.MediaType.csproj" />
	  <ProjectReference Include="..\Progress\Juniper.Progress.csproj" />
	  <ProjectReference Include="..\Root\Juniper.Root.csproj" />
	</ItemGroup>
</Project>
